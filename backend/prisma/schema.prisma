generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User & Auth ───────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(USER)
  language  String   @default("ko")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects         ProjectMember[]
  versionSnapshots VersionSnapshot[]
}

enum Role {
  ADMIN
  USER
}

// ─── Project ───────────────────────────────────────────────────

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  status      String    @default("active")
  startDate   DateTime?
  endDate     DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members          ProjectMember[]
  requirements     Requirement[]
  features         Feature[]
  tasks            Task[]
  testScenarios    TestScenario[]
  traceLinks       TraceabilityLink[]
  versionSnapshots VersionSnapshot[]
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

// ─── Requirement ───────────────────────────────────────────────

model Requirement {
  id          String   @id @default(uuid())
  projectId   String
  code        String
  title       String
  description String?
  category    String?
  priority    String   @default("medium")
  status      String   @default("new")
  source      String   @default("manual")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  features Feature[]

  @@unique([projectId, code])
}

// ─── Feature ───────────────────────────────────────────────────

model Feature {
  id           String   @id @default(uuid())
  projectId    String
  reqId        String?
  code         String
  title        String
  description  String?
  screenDesign String?
  status       String   @default("new")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirement   Requirement?    @relation(fields: [reqId], references: [id])
  tasks         Task[]
  testScenarios TestScenario[]

  @@unique([projectId, code])
}

// ─── Task ──────────────────────────────────────────────────────

model Task {
  id          String    @id @default(uuid())
  projectId   String
  featureId   String
  code        String
  title       String
  description String?
  assigneeId  String?
  progress    Int       @default(0)
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  feature  Feature     @relation(fields: [featureId], references: [id], onDelete: Cascade)
  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues   TaskIssue[]

  @@unique([projectId, code])
}

model TaskIssue {
  id          String   @id @default(uuid())
  taskId      String
  type        String   @default("issue")
  title       String
  description String?
  severity    String   @default("medium")
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ─── Test ──────────────────────────────────────────────────────

model TestScenario {
  id          String   @id @default(uuid())
  projectId   String
  featureId   String?
  reqId       String?
  code        String
  title       String
  description String?
  type        String   @default("integration")
  testData    String?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feature   Feature?   @relation(fields: [featureId], references: [id])
  testCases TestCase[]

  @@unique([projectId, code])
}

model TestCase {
  id         String    @id @default(uuid())
  scenarioId String
  type       String    @default("integration")
  title      String
  steps      Json?
  testData   String?
  expected   String?
  actual     String?
  result     String?
  executedBy String?
  executedAt DateTime?
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  scenario TestScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
}

// ─── Traceability ──────────────────────────────────────────────

model TraceabilityLink {
  id         String   @id @default(uuid())
  projectId  String
  sourceType String
  sourceId   String
  targetType String
  targetId   String
  linkType   String   @default("derives")
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId, targetType, targetId])
}

// ─── Version Snapshot ──────────────────────────────────────────

model VersionSnapshot {
  id         String   @id @default(uuid())
  projectId  String
  entityType String
  version    String
  label      String
  reason     String?
  snapshot   Json
  createdBy  String
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id])
}

// ─── LLM Config ────────────────────────────────────────────────

model LLMConfig {
  id              String   @id @default(uuid())
  provider        String
  model           String
  apiKey          String
  region          String?
  promptTemplates Json?
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Export Template ───────────────────────────────────────────

model ExportTemplate {
  id        String   @id @default(uuid())
  type      String   @unique
  title     String   @default("")
  columns   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
