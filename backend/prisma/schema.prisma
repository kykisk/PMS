generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User & Auth ───────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  nameEn    String?
  password  String
  role      Role     @default(USER)
  language  String   @default("ko")
  phone     String?
  department String?
  position  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects         ProjectMember[]
  versionSnapshots VersionSnapshot[]
  llmAccess        UserLLMAccess[]
  personalLLMs     UserLLMConfig[]
}

enum Role {
  ADMIN
  USER
}

// ─── Project ───────────────────────────────────────────────────

model Project {
  id          String    @id @default(uuid())
  name        String
  code        String?
  type        String?
  description String?
  status      String    @default("active")
  startDate   DateTime?
  endDate     DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members          ProjectMember[]
  externalMembers  ExternalProjectMember[]
  requirements     Requirement[]
  features         Feature[]
  tasks            Task[]
  taskDependencies TaskDependency[]
  testScenarios    TestScenario[]
  testCycles       TestCycle[]
  testPhases       TestPhase[]
  defects          Defect[]
  traceLinks       TraceabilityLink[]
  versionSnapshots VersionSnapshot[]
  dbTables         DbTable[]
  apiSpecs         ApiSpec[]
  changeRequests   ChangeRequest[]
  useCases         UseCase[]
  userStories      UserStory[]
  aiModelMappings  ProjectAiModelMapping[]
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   @default("MEMBER")
  note      String?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model ExternalProjectMember {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  nameEn      String?
  email       String?
  phone       String?
  role        String   @default("MEMBER")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Requirement ───────────────────────────────────────────────

model Requirement {
  id          String   @id @default(uuid())
  projectId   String
  code        String
  title       String
  description String?
  category    String?
  priority    String   @default("medium")
  status      String   @default("new")
  source      String   @default("manual")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  features Feature[]
  changeRequestRequirements ChangeRequestRequirement[]
  useCases  UseCase[]
  userStories UserStory[]
  testScenarios TestScenario[]

  @@unique([projectId, code])
}

// ─── Feature ───────────────────────────────────────────────────

model Feature {
  id           String   @id @default(uuid())
  projectId    String
  reqId        String?
  code         String
  title        String
  description  String?
  screenDesign String?
  status       String   @default("new")
  createdAt    DateTime @default(now())
  outdated     Boolean  @default(false)
  outdatedReason String?
  updatedAt    DateTime @updatedAt

  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirement   Requirement?    @relation(fields: [reqId], references: [id])
  tasks         Task[]
  testScenarios TestScenario[]
  dbTables      DbTable[]
  apiSpecs      ApiSpec[]
  screenImages  ScreenImage[]

  @@unique([projectId, code])
}

model ScreenImage {
  id          String   @id @default(uuid())
  featureId   String
  filename    String
  originalName String
  url         String
  size        Int?
  mimeType    String?
  createdAt   DateTime @default(now())
  feature     Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
}

// ─── Task ──────────────────────────────────────────────────────

model Task {
  id          String    @id @default(uuid())
  projectId   String
  featureId   String
  code        String
  title       String
  description String?
  assigneeId  String?
  progress    Int       @default(0)
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("pending")
  outdated     Boolean  @default(false)
  outdatedReason String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  feature  Feature     @relation(fields: [featureId], references: [id], onDelete: Cascade)
  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues   TaskIssue[]
  depsFrom TaskDependency[] @relation("DepFrom")
  depsTo   TaskDependency[] @relation("DepTo")

  @@unique([projectId, code])
}

model TaskDependency {
  id         String   @id @default(uuid())
  projectId  String
  fromTaskId String
  toTaskId   String
  type       String   @default("FS")
  createdAt  DateTime @default(now())

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromTask Task    @relation("DepFrom", fields: [fromTaskId], references: [id], onDelete: Cascade)
  toTask   Task    @relation("DepTo", fields: [toTaskId], references: [id], onDelete: Cascade)

  @@unique([fromTaskId, toTaskId])
}

model TaskIssue {
  id          String   @id @default(uuid())
  taskId      String
  type        String   @default("issue")
  title       String
  description String?
  severity    String   @default("medium")
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ─── Test ──────────────────────────────────────────────────────

model TestScenario {
  id             String   @id @default(uuid())
  projectId      String
  featureId      String?
  reqId          String?
  code           String
  title          String
  description    String?
  type           String   @default("integration")  // unit | integration | system | acceptance
  testType       String   @default("functional")   // functional | performance | security | usability | compatibility
  testData       String?
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  outdated       Boolean  @default(false)
  outdatedReason String?

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feature     Feature?     @relation(fields: [featureId], references: [id])
  requirement Requirement? @relation(fields: [reqId], references: [id])
  testCases   TestCase[]

  @@unique([projectId, code])
  @@index([projectId, type])
  @@index([projectId, testType])
  @@index([projectId, featureId])
  @@index([projectId, reqId])
}

model TestCase {
  id         String    @id @default(uuid())
  scenarioId String
  type       String    @default("integration")
  title      String
  priority   String    @default("medium")  // high | medium | low
  steps      Json?
  testData   String?
  expected   String?
  actual     String?
  result     String?
  executedBy String?
  executedAt DateTime?
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  scenario   TestScenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  executions TestExecution[]
}

// ─── TestCycle ─────────────────────────────────────────────────

model TestCycle {
  id          String    @id @default(uuid())
  projectId   String
  code        String
  title       String
  description String?
  scope       String    @default("full")     // full | partial | regression
  status      String    @default("planned")  // planned | in_progress | completed | cancelled
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  executions TestExecution[]

  @@unique([projectId, code])
}

// ─── TestExecution ─────────────────────────────────────────────

model TestExecution {
  id          String   @id @default(uuid())
  testCaseId  String
  cycleId     String
  result      String   // pass | fail | blocked | skipped
  actual      String?
  note        String?
  executedBy  String?
  executedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  testCase TestCase  @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  cycle    TestCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  defects  Defect[]

  @@index([testCaseId, cycleId])
}

// ─── Defect ────────────────────────────────────────────────────

model Defect {
  id          String    @id @default(uuid())
  projectId   String
  code        String
  title       String
  description String?
  severity    String    @default("major")   // critical | major | minor | trivial
  priority    String    @default("medium")  // high | medium | low
  status      String    @default("open")    // open | assigned | in_progress | resolved | verified | closed | reopened
  assigneeId  String?
  reportedBy  String?
  executionId String?
  resolution  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  execution TestExecution? @relation(fields: [executionId], references: [id], onDelete: SetNull)

  @@unique([projectId, code])
}

// ─── Traceability ──────────────────────────────────────────────

model TraceabilityLink {
  id         String   @id @default(uuid())
  projectId  String
  sourceType String
  sourceId   String
  targetType String
  targetId   String
  linkType   String   @default("derives")
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId, targetType, targetId])
}

// ─── Version Snapshot ──────────────────────────────────────────

model VersionSnapshot {
  id         String   @id @default(uuid())
  projectId  String
  entityType String
  version    String
  label      String
  reason     String?
  snapshot   Json
  createdBy  String
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id])
}

// ─── LLM Config ────────────────────────────────────────────────

model LLMConfig {
  id              String   @id @default(uuid())
  provider        String
  model           String
  apiKey          String
  region          String?
  promptTemplates Json?
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userAccess      UserLLMAccess[]
}

model UserLLMAccess {
  id          String    @id @default(uuid())
  userId      String
  llmConfigId String
  grantedAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  llmConfig   LLMConfig @relation(fields: [llmConfigId], references: [id], onDelete: Cascade)
  @@unique([userId, llmConfigId])
}

model UserLLMConfig {
  id        String   @id @default(uuid())
  userId    String
  provider  String
  model     String
  apiKey    String
  region    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Export Template ───────────────────────────────────────────

model ExportTemplate {
  id        String   @id @default(uuid())
  type      String   @unique
  title     String   @default("")
  columns   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── AI Feature Model Mapping ──────────────────────────────────

model ProjectAiModelMapping {
  id              String   @id @default(uuid())
  projectId       String
  featureKey      String
  llmConfigId     String?
  userLlmConfigId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, featureKey])
}

model DbTable {
  id          String      @id @default(uuid())
  projectId   String
  featureId   String?
  name        String
  description String?
  columns     Json
  indexes     Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feature     Feature?    @relation(fields: [featureId], references: [id], onDelete: SetNull)
}

model ApiSpec {
  id           String   @id @default(uuid())
  projectId    String
  featureId    String?
  method       String
  path         String
  summary      String
  description  String?
  requestBody  Json?
  responseBody Json?
  parameters   Json?
  statusCodes  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feature      Feature? @relation(fields: [featureId], references: [id], onDelete: SetNull)
}

model ChangeRequest {
  id              String   @id @default(uuid())
  projectId       String
  code            String
  title           String
  description     String?
  reason          String?
  status          String   @default("draft")
  priority        String   @default("medium")
  requestedBy     String?
  approvedBy      String?
  affectedItems   Json?
  aiAnalysis      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirements    ChangeRequestRequirement[]
}

model ChangeRequestRequirement {
  id              String        @id @default(uuid())
  changeRequestId String
  requirementId   String
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  requirement     Requirement   @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  @@unique([changeRequestId, requirementId])
}

model UseCase {
  id           String   @id @default(uuid())
  projectId    String
  code         String
  title        String
  actor        String?
  description  String?
  precondition String?
  mainFlow     Json?
  altFlow      Json?
  postcondition String?
  priority     String   @default("medium")
  status       String   @default("draft")
  requirementId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirement  Requirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)
}

model UserStory {
  id             String   @id @default(uuid())
  projectId      String
  code           String
  title          String
  asA            String?
  iWantTo        String?
  soThat         String?
  acceptanceCriteria Json?
  priority       String   @default("medium")
  status         String   @default("draft")
  storyPoints    Int?
  requirementId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirement    Requirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id          String   @id @default(uuid())
  projectId   String
  entityType  String
  entityId    String
  entityCode  String?
  action      String
  changes     Json?
  userId      String?
  userName    String?
  createdAt   DateTime @default(now())

  @@index([projectId, entityType, entityId])
  @@index([projectId, createdAt])
}

model SpecDocument {
  id          String   @id @default(uuid())
  projectId   String
  content     String
  version     Int      @default(1)
  uploadedAt  DateTime @default(now())

  @@index([projectId])
}

// ─── Test Execution (테스트 수행) ──────────────────────────────

model TestPhase {
  id          String    @id @default(uuid())
  projectId   String
  code        String
  title       String
  description String?
  phaseType   String    @default("system")   // integration | system | acceptance
  status      String    @default("planned")
  startDate   DateTime?
  endDate     DateTime?
  snapshotData Json?
  snapshotAt  DateTime?
  outdated    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rounds  TestRound[]

  @@unique([projectId, code])
}

model TestRound {
  id            String    @id @default(uuid())
  phaseId       String
  roundNumber   Int
  testerName    String
  testerDept    String?
  executedAt    DateTime?
  scope         String    @default("full")
  sourceRoundId String?
  totalCases    Int       @default(0)
  passCount     Int       @default(0)
  failCount     Int       @default(0)
  blockedCount  Int       @default(0)
  naCount       Int       @default(0)
  importedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  phase   TestPhase         @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  results TestRoundResult[]

  @@index([phaseId, roundNumber])
}

model TestRoundResult {
  id           String  @id @default(uuid())
  roundId      String
  scenarioCode String
  caseTitle    String
  caseIndex    Int
  result       String?
  actual       String?
  stepResults  Json?
  defectId     String?
  createdAt    DateTime @default(now())

  round TestRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId, scenarioCode, caseTitle])
}
