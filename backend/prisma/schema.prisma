generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User & Auth ───────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  nameEn    String?
  password  String
  role      Role     @default(USER)
  language  String   @default("ko")
  phone     String?
  department String?
  position  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects         ProjectMember[]
  versionSnapshots VersionSnapshot[]
  llmAccess        UserLLMAccess[]
  personalLLMs     UserLLMConfig[]
}

enum Role {
  ADMIN
  USER
}

// ─── Project ───────────────────────────────────────────────────

model Project {
  id          String    @id @default(uuid())
  name        String
  code        String?
  type        String?
  description String?
  status      String    @default("active")
  startDate   DateTime?
  endDate     DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members          ProjectMember[]
  externalMembers  ExternalProjectMember[]
  requirements     Requirement[]
  features         Feature[]
  tasks            Task[]
  testScenarios    TestScenario[]
  traceLinks       TraceabilityLink[]
  versionSnapshots VersionSnapshot[]
  dbTables         DbTable[]
  apiSpecs         ApiSpec[]
  changeRequests   ChangeRequest[]
  useCases         UseCase[]
  userStories      UserStory[]
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   @default("MEMBER")
  note      String?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model ExternalProjectMember {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  nameEn      String?
  email       String?
  phone       String?
  role        String   @default("MEMBER")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Requirement ───────────────────────────────────────────────

model Requirement {
  id          String   @id @default(uuid())
  projectId   String
  code        String
  title       String
  description String?
  category    String?
  priority    String   @default("medium")
  status      String   @default("new")
  source      String   @default("manual")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  features Feature[]
  changeRequestRequirements ChangeRequestRequirement[]
  useCases  UseCase[]
  userStories UserStory[]
  testScenarios TestScenario[]

  @@unique([projectId, code])
}

// ─── Feature ───────────────────────────────────────────────────

model Feature {
  id           String   @id @default(uuid())
  projectId    String
  reqId        String?
  code         String
  title        String
  description  String?
  screenDesign String?
  status       String   @default("new")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirement   Requirement?    @relation(fields: [reqId], references: [id])
  tasks         Task[]
  testScenarios TestScenario[]
  dbTables      DbTable[]
  apiSpecs      ApiSpec[]
  screenImages  ScreenImage[]

  @@unique([projectId, code])
}

model ScreenImage {
  id          String   @id @default(uuid())
  featureId   String
  filename    String
  originalName String
  url         String
  size        Int?
  mimeType    String?
  createdAt   DateTime @default(now())
  feature     Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
}

// ─── Task ──────────────────────────────────────────────────────

model Task {
  id          String    @id @default(uuid())
  projectId   String
  featureId   String
  code        String
  title       String
  description String?
  assigneeId  String?
  progress    Int       @default(0)
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  feature  Feature     @relation(fields: [featureId], references: [id], onDelete: Cascade)
  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues   TaskIssue[]

  @@unique([projectId, code])
}

model TaskIssue {
  id          String   @id @default(uuid())
  taskId      String
  type        String   @default("issue")
  title       String
  description String?
  severity    String   @default("medium")
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ─── Test ──────────────────────────────────────────────────────

model TestScenario {
  id          String   @id @default(uuid())
  projectId   String
  featureId   String?
  reqId       String?
  code        String
  title       String
  description String?
  type        String   @default("integration")
  testData    String?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feature     Feature?     @relation(fields: [featureId], references: [id])
  requirement Requirement? @relation(fields: [reqId], references: [id])
  testCases   TestCase[]

  @@unique([projectId, code])
}

model TestCase {
  id         String    @id @default(uuid())
  scenarioId String
  type       String    @default("integration")
  title      String
  steps      Json?
  testData   String?
  expected   String?
  actual     String?
  result     String?
  executedBy String?
  executedAt DateTime?
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  scenario TestScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
}

// ─── Traceability ──────────────────────────────────────────────

model TraceabilityLink {
  id         String   @id @default(uuid())
  projectId  String
  sourceType String
  sourceId   String
  targetType String
  targetId   String
  linkType   String   @default("derives")
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId, targetType, targetId])
}

// ─── Version Snapshot ──────────────────────────────────────────

model VersionSnapshot {
  id         String   @id @default(uuid())
  projectId  String
  entityType String
  version    String
  label      String
  reason     String?
  snapshot   Json
  createdBy  String
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id])
}

// ─── LLM Config ────────────────────────────────────────────────

model LLMConfig {
  id              String   @id @default(uuid())
  provider        String
  model           String
  apiKey          String
  region          String?
  promptTemplates Json?
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userAccess      UserLLMAccess[]
}

model UserLLMAccess {
  id          String    @id @default(uuid())
  userId      String
  llmConfigId String
  grantedAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  llmConfig   LLMConfig @relation(fields: [llmConfigId], references: [id], onDelete: Cascade)
  @@unique([userId, llmConfigId])
}

model UserLLMConfig {
  id        String   @id @default(uuid())
  userId    String
  provider  String
  model     String
  apiKey    String
  region    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Export Template ───────────────────────────────────────────

model ExportTemplate {
  id        String   @id @default(uuid())
  type      String   @unique
  title     String   @default("")
  columns   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DbTable {
  id          String      @id @default(uuid())
  projectId   String
  featureId   String?
  name        String
  description String?
  columns     Json
  indexes     Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feature     Feature?    @relation(fields: [featureId], references: [id], onDelete: SetNull)
}

model ApiSpec {
  id           String   @id @default(uuid())
  projectId    String
  featureId    String?
  method       String
  path         String
  summary      String
  description  String?
  requestBody  Json?
  responseBody Json?
  parameters   Json?
  statusCodes  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feature      Feature? @relation(fields: [featureId], references: [id], onDelete: SetNull)
}

model ChangeRequest {
  id              String   @id @default(uuid())
  projectId       String
  code            String
  title           String
  description     String?
  reason          String?
  status          String   @default("draft")
  priority        String   @default("medium")
  requestedBy     String?
  approvedBy      String?
  affectedItems   Json?
  aiAnalysis      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirements    ChangeRequestRequirement[]
}

model ChangeRequestRequirement {
  id              String        @id @default(uuid())
  changeRequestId String
  requirementId   String
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  requirement     Requirement   @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  @@unique([changeRequestId, requirementId])
}

model UseCase {
  id           String   @id @default(uuid())
  projectId    String
  code         String
  title        String
  actor        String?
  description  String?
  precondition String?
  mainFlow     Json?
  altFlow      Json?
  postcondition String?
  priority     String   @default("medium")
  status       String   @default("draft")
  requirementId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirement  Requirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)
}

model UserStory {
  id             String   @id @default(uuid())
  projectId      String
  code           String
  title          String
  asA            String?
  iWantTo        String?
  soThat         String?
  acceptanceCriteria Json?
  priority       String   @default("medium")
  status         String   @default("draft")
  storyPoints    Int?
  requirementId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirement    Requirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)
}
